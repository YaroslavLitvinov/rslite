{
  "type": "Spec",
  "model_version": 1,
  "version": 1,
  "description": "Verify c_variadic feature isolation: only in printf_c_variadic.rs",
  "contains_unverified_constraints": false,
  "features": {
    "build_all": {
      "type": "Feature",
      "model_version": 1,
      "id": "build_all",
      "description": "Check that our rust codebase is healthy",
      "goals": [],
      "constraints": {
        "constraint_build_all": {
          "id": "constraint_build_all",
          "cmd": "cd $WORKSPACE_ROOT && ./build_all.sh",
          "description": "Ensure our rust codebase is healthy",
          "fails_count": 1
        }
      }
    },
    "toolchain_version": {
      "type": "Feature",
      "model_version": 1,
      "id": "toolchain_version",
      "description": "Enforce Rust toolchain version nightly-2026-03-26",
      "goals": [
        "rust-toolchain.toml must specify channel nightly-2026-03-26"
      ],
      "constraints": {
        "c6": {
          "id": "toolchain_nightly_version",
          "cmd": "grep -q \"nightly-2026-03-26\" \"$PROJECT_ROOT/rust-toolchain.toml\" && exit 0 || exit 1",
          "description": "rust-toolchain.toml must use channel nightly-2026-03-26",
          "fails_count": 1
        }
      }
    },
    "memdb_c_variadic_migration": {
      "type": "Feature",
      "model_version": 1,
      "id": "memdb_c_variadic_migration",
      "description": "Migrate memdb.rs and specific functions away from c_variadic feature",
      "goals": [
        "Remove c_variadic feature usage from memdb.rs file",
        "Refactor memdbFileControl function to eliminate c_variadic",
        "Refactor sqlite3_serialize function to eliminate c_variadic",
        "Refactor sqlite3_deserialize function to eliminate c_variadic"
      ],
      "constraints": {
        "memdb_no_feature": {
          "id": "memdb_no_c_variadic_feature",
          "cmd": "grep -n '#!\\[feature(c_variadic)\\]' \"$WORKSPACE_ROOT/src/src/memdb.rs\" 2>/dev/null && exit 1 || exit 0",
          "description": "memdb.rs must not have c_variadic feature declaration",
          "fails_count": 1
        },
        "memdb_memdbFileControl_no_variadic": {
          "id": "memdb_memdbFileControl_no_variadic",
          "cmd": "awk '/^[^/]*fn memdbFileControl/,/^}/' \"$WORKSPACE_ROOT/src/src/memdb.rs\" 2>/dev/null | grep -E '(va_list|VAList|VaListImpl|c_variadic|va_arg)' && exit 1 || exit 0",
          "description": "memdbFileControl function must not use c_variadic or variadic patterns",
          "fails_count": 1
        },
        "memdb_sqlite3_serialize_no_variadic": {
          "id": "memdb_sqlite3_serialize_no_variadic",
          "cmd": "awk '/^[^/]*fn sqlite3_serialize/,/^}/' \"$WORKSPACE_ROOT/src/src/memdb.rs\" 2>/dev/null | grep -E '(va_list|VAList|VaListImpl|c_variadic|va_arg)' && exit 1 || exit 0",
          "description": "sqlite3_serialize function must not use c_variadic or variadic patterns",
          "fails_count": 1
        },
        "memdb_sqlite3_deserialize_no_variadic": {
          "id": "memdb_sqlite3_deserialize_no_variadic",
          "cmd": "awk '/^[^/]*fn sqlite3_deserialize/,/^}/' \"$WORKSPACE_ROOT/src/src/memdb.rs\" 2>/dev/null | grep -E '(va_list|VAList|VaListImpl|c_variadic|va_arg)' && exit 1 || exit 0",
          "description": "sqlite3_deserialize function must not use c_variadic or variadic patterns",
          "fails_count": 1
        },
        "memdb_no_sqlite3_mprintf": {
          "id": "memdb_no_sqlite3_mprintf",
          "cmd": "grep -E \"sqlite3_mprintf\\(\" \"$WORKSPACE_ROOT/src/src/memdb.rs\" 2>/dev/null && exit 1 || exit 0",
          "description": "memdb.rs must not use sqlite3_mprintf",
          "fails_count": 1
        },
        "memdb_no_sqlite3_mprintf_use": {
          "id": "memdb_no_sqlite3_mprintf_use",
          "cmd": "grep -E \"use.*sqlite3_mprintf|pub use.*sqlite3_mprintf\" \"$WORKSPACE_ROOT/src/src/memdb.rs\" 2>/dev/null && exit 1 || exit 0",
          "description": "memdb.rs must not import sqlite3_mprintf",
          "fails_count": 1
        }
      }
    },
    "fts3_write_c_variadic_migration": {
      "type": "Feature",
      "model_version": 1,
      "id": "fts3_write_c_variadic_migration",
      "description": "Migrate fts3_write.rs and specific functions away from c_variadic feature",
      "goals": [
        "Remove c_variadic feature usage from fts3_write.rs file",
        "Refactor fts3SqlStmt function to eliminate c_variadic",
        "Refactor fts3SqlExec function to eliminate c_variadic",
        "Replace all sqlite3_mprintf calls with compile-time validated macros"
      ],
      "constraints": {
        "fts3_write_no_feature": {
          "id": "fts3_write_no_c_variadic_feature",
          "cmd": "grep -n \"#!\\[feature(c_variadic)\\]\" \"$WORKSPACE_ROOT/src/ext/fts3/fts3_write.rs\" 2>/dev/null && exit 1 || exit 0",
          "description": "fts3_write.rs must not have c_variadic feature declaration",
          "fails_count": 1
        },
        "fts3_write_fts3SqlStmt_no_variadic": {
          "id": "fts3_write_fts3SqlStmt_no_variadic",
          "cmd": "awk \"/^[^/]*fn fts3SqlStmt/,/^}/\" \"$WORKSPACE_ROOT/src/ext/fts3/fts3_write.rs\" 2>/dev/null | grep -E \"(va_list|VAList|VaListImpl|c_variadic|va_arg)\" && exit 1 || exit 0",
          "description": "fts3SqlStmt function must not use c_variadic or variadic patterns",
          "fails_count": 1
        },
        "fts3_write_fts3SqlExec_no_variadic": {
          "id": "fts3_write_fts3SqlExec_no_variadic",
          "cmd": "awk \"/^[^/]*fn fts3SqlExec/,/^}/\" \"$WORKSPACE_ROOT/src/ext/fts3/fts3_write.rs\" 2>/dev/null | grep -E \"(va_list|VAList|VaListImpl|c_variadic|va_arg)\" && exit 1 || exit 0",
          "description": "fts3SqlExec function must not use c_variadic or variadic patterns",
          "fails_count": 1
        },
        "fts3_write_no_sqlite3_mprintf": {
          "id": "fts3_write_no_sqlite3_mprintf",
          "cmd": "grep -E \"sqlite3_mprintf\\(\" \"$WORKSPACE_ROOT/src/ext/fts3/fts3_write.rs\" 2>/dev/null && exit 1 || exit 0",
          "description": "fts3_write.rs must not use sqlite3_mprintf function calls",
          "fails_count": 1
        },
        "fts3_write_no_sqlite3_mprintf_use": {
          "id": "fts3_write_no_sqlite3_mprintf_use",
          "cmd": "grep -E \"use.*sqlite3_mprintf|pub use.*sqlite3_mprintf\" \"$WORKSPACE_ROOT/src/ext/fts3/fts3_write.rs\" 2>/dev/null && exit 1 || exit 0",
          "description": "fts3_write.rs must not import sqlite3_mprintf",
          "fails_count": 1
        }
      }
    }
  }
}